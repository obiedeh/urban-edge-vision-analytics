# Detection backend
# Options: mock | nvidia-nim | nvidia-vss | nvidia-cosmos
DETECTION_ADAPTER=mock

# For NVIDIA-backed adapters. Leave unset while using mock.
NVIDIA_VISION_ENDPOINT=
NVIDIA_VISION_MODEL=
NVIDIA_API_KEY=

# API server
API_HOST=0.0.0.0
API_PORT=8080

# Camera sources (comma-separated RTSP URIs or video file paths)
CAMERA_SOURCES=

# Real camera startup validation
# Copy configs/camera.local.example.json to a local file and set CAMERA_CONFIG to that path.
CAMERA_CONFIG=
CAMERA_REQUIRE_FFPLAY=0
CAMERA_USERNAME=
CAMERA_PASSWORD=

# Congestion threshold (vehicles per frame to trigger congestion event)
CONGESTION_THRESHOLD=10

# Flow window size (frames)
FLOW_WINDOW_SIZE=30
