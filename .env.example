# Detection backend
# Options: mock | onnx | tensorrt | openai-compatible
DETECTION_ADAPTER=mock

# For openai-compatible adapters (e.g., local vLLM, NVIDIA NIM)
DETECTION_ENDPOINT=http://localhost:8000/v1
DETECTION_MODEL=yolov8n

# API server
API_HOST=0.0.0.0
API_PORT=8080

# Camera sources (comma-separated RTSP URIs or video file paths)
CAMERA_SOURCES=

# Congestion threshold (vehicles per frame to trigger congestion event)
CONGESTION_THRESHOLD=10

# Flow window size (frames)
FLOW_WINDOW_SIZE=30
